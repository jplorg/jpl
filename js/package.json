{
  "name": "@jplorg/jpl",
  "version": "2.1.1",
  "description": "JPL interpreter",
  "license": "MIT",
  "author": {
    "name": "Aaron Burmeister"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jplorg/jpl.git"
  },
  "bugs": {
    "url": "https://github.com/jplorg/jpl/issues"
  },
  "homepage": "https://github.com/jplorg/jpl",
  "type": "module",
  "keywords": [
    "jpl",
    "json",
    "cli"
  ],
  "files": [
    "dist",
    "repl.ts"
  ],
  "types": "./dist/types/main.d.ts",
  "main": "./dist/esm/main.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/main.d.ts",
        "default": "./dist/esm/main.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "jpl-repl": "./repl.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b ./tsconfig-build.json && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "prettify": "prettier . --write",
    "preview": "vite preview",
    "postversion": "git commit -am$npm_package_version",
    "prepublishOnly": "npm run build",
    "start": "npm run build >/dev/null && ./repl.ts",
    "repl": "./repl.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unplugin-dts": "^1.0.1",
    "vite": "^8.0.12"
  }
}
